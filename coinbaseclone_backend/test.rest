@base = http://localhost:5000

# ─────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────

### Register a new user
POST {{base}}/api/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "test@example.com",
  "password": "password123"
}

###

### Login
POST {{base}}/api/auth/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password123"
}

###

### Get profile (requires cookie from login)
GET {{base}}/api/auth/profile

###

### Promote to admin (requires cookie from login)
POST {{base}}/api/auth/make-admin

###

### Logout
POST {{base}}/api/auth/logout

# ─────────────────────────────────────────────
# SEED — bulk insert all cryptos at once
# Run this if the database is empty.
# Safe to call multiple times (no-op if data exists).
# ─────────────────────────────────────────────

### Seed all cryptocurrencies
POST {{base}}/api/crypto/seed

# ─────────────────────────────────────────────
# CRYPTO — read endpoints
# ─────────────────────────────────────────────

### Get all cryptos (page 1, 20 per page)
GET {{base}}/api/crypto?page=1&limit=20

###

### Get top gainers
GET {{base}}/api/crypto/gainers?limit=10

###

### Get newest listings
GET {{base}}/api/crypto/new?limit=10

